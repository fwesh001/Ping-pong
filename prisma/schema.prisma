// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String     @id @default(cuid())
  fluxUserId        String     @unique @map("flux_user_id")
  creditBalance     Int        @default(100) @map("credit_balance")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  
  monitors          Monitor[]
  pingLogs          PingLog[]
  dailyCredits      DailyCreditClaim[]

  @@map("users")
}

model Monitor {
  id                String     @id @default(cuid())
  userId            String     @map("user_id")
  serviceName       String     @map("service_name")
  targetUrl         String     @map("target_url")
  pingIntervalSecs  Int        @default(60) @map("ping_interval_seconds")
  timeoutMs         Int        @default(10000) @map("timeout_ms")
  isActive          Boolean    @default(true) @map("is_active")
  lastPingedAt      DateTime?  @map("last_pinged_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pingLogs          PingLog[]

  @@index([userId])
  @@map("monitors")
}

model PingLog {
  id                String     @id @default(cuid())
  monitorId         String     @map("monitor_id")
  userId            String     @map("user_id")
  status            String     // "success", "failure", "timeout"
  responseTimeMs    Int?       @map("response_time_ms")
  statusCode        Int?       @map("status_code")
  errorMessage      String?    @map("error_message")
  checkedAt         DateTime   @map("checked_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  
  monitor           Monitor    @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([monitorId])
  @@index([userId])
  @@map("ping_logs")
}

model DailyCreditClaim {
  id                String     @id @default(cuid())
  userId            String     @map("user_id")
  claimedAt         DateTime   @map("claimed_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, claimedAt]) // One claim per user per day
  @@index([userId])
  @@map("daily_credit_claims")
}
