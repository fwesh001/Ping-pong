generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String             @id @default(cuid())
  fluxUserId    String             @unique
  creditBalance Float              @default(100.0)
  streakCount   Int                @default(0)
  lastClaimedAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  dailyCredits  DailyCreditClaim[]
  monitors      Monitor[]
  pingLogs      PingLog[]
}

model Monitor {
  id               String    @id @default(cuid())
  userId           String
  serviceName      String
  targetUrl        String
  scheduleMode     String    @default("RECURRING")
  pingIntervalSecs Int?
  timeoutMs        Int       @default(10000)
  maxRetries       Int       @default(0)
  activeDays       String?
  executeTime      String?
  executeDate      DateTime?
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  isCompleted      Boolean   @default(false)
  costPerPing      Float     @default(0.01389)
  lastPingedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pingLogs         PingLog[]

  @@index([userId])
}

model PingLog {
  id             String   @id @default(cuid())
  monitorId      String
  userId         String
  status         String
  responseTimeMs Int?
  statusCode     Int?
  errorMessage   String?
  checkedAt      DateTime
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitor        Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId])
  @@index([userId])
}

model DailyCreditClaim {
  id        String   @id @default(cuid())
  userId    String
  claimedAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, claimedAt])
  @@index([userId])
}
