# Database
DATABASE_URL="file:./dev.db"

# Flux Authentication
FLUX_API_URL="https://api.flux.example.com"
FLUX_API_KEY="your_flux_api_key_here"

# Session Management
SESSION_SECRET="your_session_secret_key_here_minimum_32_chars"

# Cron Security
CRON_SECRET="your_cron_endpoint_secret_here"

# Credit System
INITIAL_CREDIT_BALANCE=100
DAILY_CREDIT_REWARD=10
CREDIT_COST_PER_PING=1

# Ping Configuration (in seconds & milliseconds)
DEFAULT_PING_INTERVAL=60
MIN_PING_INTERVAL=30
MAX_PING_INTERVAL=3600
PING_TIMEOUT_MS=10000

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
